# ============================================
# 智扫通机器人智能客服 - 环境变量配置模板
# ============================================
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env (Linux/Mac) 或 copy .env.example .env (Windows)
# 2. 填写实际的配置值（删除注释中的示例值）
# 3. .env 文件已添加到 .gitignore，不会提交到版本控制
# 4. Docker 部署时，修改后需重启容器: docker-compose restart backend
# 5. 本地开发时，修改后需重启 Python 进程
# ============================================

# --------------------------------------------
# API Keys (敏感信息)
# --------------------------------------------
# 高德地图 API Key（用于天气查询和位置定位）
# 获取方式：访问 https://console.amap.com/dev/key/app 注册应用
AMAP_API_KEY=your_amap_api_key_here

# --------------------------------------------
# 模型服务配置
# --------------------------------------------
# Ollama 服务地址
# 不同操作系统的配置：
#   - Windows/Mac: http://host.docker.internal:11434 (Docker) 或 http://localhost:11434 (本地)
#   - Linux: http://<宿主机IP>:11434 (Docker) 或 http://localhost:11434 (本地)
#   - 如果使用阿里云 API，此项可不配置
OLLAMA_BASE_URL=http://localhost:11434

# 聊天模型提供商: ollama 或 aliyun
CHAT_MODEL_PROVIDER=ollama
# 聊天模型名称
# Ollama 模型: qwen2.5:7b, llama3.2:3b, 等
# 阿里云模型: qwen-plus, qwen-max, 等
CHAT_MODEL_NAME=qwen2.5:7b

# 嵌入模型提供商: ollama 或 aliyun
EMBEDDING_MODEL_PROVIDER=ollama
# 嵌入模型名称
# Ollama 模型: qwen3-embedding:latest, nomic-embed-text, 等
# 阿里云模型: text-embedding-v3, 等
EMBEDDING_MODEL_NAME=qwen3-embedding:latest

# Rerank 模型设备: cpu 或 cuda
# 如果有 NVIDIA GPU，建议设置为 cuda 以提升性能
RERANK_DEVICE=cpu

# --------------------------------------------
# MongoDB 聊天历史存储配置
# --------------------------------------------
# MongoDB 服务地址
# 不同部署方式的配置：
#   1. 本地安装 MongoDB:
#      - Windows/Mac: mongodb://localhost:27017
#      - Linux: mongodb://localhost:27017
#   2. Docker 容器运行 (需在 docker-compose.yml 中启用 mongodb 服务):
#      - mongodb://mongodb:27017
#   3. Docker 连接本地 MongoDB:
#      - Windows/Mac: mongodb://host.docker.internal:27017
#      - Linux: mongodb://<宿主机IP>:27017
MONGODB_URI=mongodb://localhost:27017

# --------------------------------------------
# Milvus 向量数据库配置
# --------------------------------------------
# Milvus 服务地址
# 不同部署方式的配置：
#   1. 本地安装 Milvus:
#      - 所有系统: http://localhost:19530
#   2. Docker 容器运行 (需在 docker-compose.yml 中启用 milvus 服务):
#      - http://milvus:19530
#   3. Docker 连接本地 Milvus:
#      - Windows/Mac: http://host.docker.internal:19530
#      - Linux: http://<宿主机IP>:19530
MILVUS_URI=http://localhost:19530

# Collection 名称（向量库表名）
MILVUS_COLLECTION_NAME=agent

# --------------------------------------------
# 应用服务配置
# --------------------------------------------
# 后端 API 地址（前端使用）
API_BASE_URL=http://localhost:8000

# 后端服务端口
BACKEND_PORT=8000

# 前端服务端口
FRONTEND_PORT=8501

# --------------------------------------------
# 其他配置
# --------------------------------------------
# 日志级别: DEBUG, INFO, WARNING, ERROR
# 开发环境建议使用 DEBUG，生产环境建议使用 INFO
LOG_LEVEL=INFO

# Rerank 模型路径（相对项目根目录）
# 默认使用本地模型: model/BAAI-bge-reranker-v2-m3
# 如需使用 HuggingFace 在线模型，可设置为: BAAI/bge-reranker-v2-m3
RERANK_MODEL_PATH=model/BAAI-bge-reranker-v2-m3
